{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Maz Client Intake Form",
  "type": "object",
  "required": ["client", "business", "website"],
  "properties": {
    "client": {
      "type": "object",
      "required": ["name", "slug", "primary_contact"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
        "primary_contact": {
          "type": "object",
          "required": ["name", "email"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "business": {
      "type": "object",
      "required": ["description", "audience", "offer"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "audience": { "type": "string", "minLength": 1 },
        "offer": { "type": "string", "minLength": 1 },
        "differentiators": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "website": {
      "type": "object",
      "required": ["goal", "pages"],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "domain": { "type": "string" },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["slug", "title", "purpose"],
            "properties": {
              "slug": { "type": "string" },
              "title": { "type": "string" },
              "purpose": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
